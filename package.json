{
  "dependencies": {
    "@tailwindcss/cli": "^4.3.1",
    "tailwindcss": "^4.3.1"
  },
  "scripts": {
    "dev:css": "tailwindcss -i ./src/input.css -o ./public/assets/css/style.css --watch",
    "build:css": "tailwindcss -i ./src/input.css -o ./public/assets/css/style.css --minify",
    "dev:pages": "node scripts/build-pages.js --watch",
    "build:pages": "node scripts/build-pages.js",
    "dev": "npm-run-all --parallel dev:css dev:pages",
    "build": "npm run build:css && npm run build:pages"
  }
}
